# ============================================
# LaTeX RENDERING SUPPORT
# ============================================

from PyQt6.QtWidgets import QLabel
from PyQt6.QtCore import Qt

def render_latex_to_html(latex_str):
    """Convert LaTeX to HTML for QLabel display"""
    import re
    # Replace \( ... \) with $$ ... $$ for HTML math
    html = re.sub(r'\\\((.*?)\\\)', r'$$\1$$', latex_str)
    # Replace \sqrt with √ for basic fallback
    html = html.replace(r'\sqrt', '√')
    html = html.replace(r'\{', '{').replace(r'\}', '}')
    return f'<html><body style="color:#cdd6f4; font-size:14px;">{html}</body></html>'

# Override the question label to use HTML rendering
def set_math_text(label, text):
    """Set text on QLabel with LaTeX support"""
    if '\\' in text or '^' in text or '_' in text:
        label.setText(render_latex_to_html(text))
        label.setTextFormat(Qt.TextFormat.RichText)
    else:
        label.setText(text)
        label.setTextFormat(Qt.TextFormat.PlainText)
