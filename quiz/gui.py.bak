from PyQt6.QtCore import QUrl, QByteArray
from PyQt6.QtGui import QDesktopServices

def show_image_in_viewer(image_path):
    """Force image to open in Okular from stream"""
    if image_path and os.path.exists(image_path):
        subprocess.Popen(["okular", image_path], env=_env())

# Override the graph display to use streaming
def safe_show_graph(q):
    """Wrapper that handles missing graphs gracefully"""
    try:
        from quiz.core.graph_utils import show_graph_for_question
        show_graph_for_question(q)
    except Exception as e:
        print(f"[gui] Graph failed (streaming): {e}")

